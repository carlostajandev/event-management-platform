#!/bin/sh
EP="http://localhost:4566"
AWS="aws --endpoint-url $EP --region us-east-1"

echo "🚀 Inicializando colas SQS para PRUEBAS..."

# Crear DLQ de prueba
DLQ_URL=$($AWS sqs create-queue \
  --queue-name emp-test-purchase-orders-dlq \
  --attributes MessageRetentionPeriod=1209600 \
  --query 'QueueUrl' --output text 2>/dev/null || echo "")

if [ -z "$DLQ_URL" ]; then
    echo "DLQ ya existe, obteniendo URL..."
    DLQ_URL=$($AWS sqs get-queue-url --queue-name emp-test-purchase-orders-dlq --query 'QueueUrl' --output text)
fi

DLQ_ARN=$($AWS sqs get-queue-attributes \
  --queue-url "$DLQ_URL" \
  --attribute-names QueueArn \
  --query 'Attributes.QueueArn' --output text)

# Crear cola principal de prueba con DLQ
$AWS sqs create-queue \
  --queue-name emp-test-purchase-orders \
  --attributes "VisibilityTimeout=30,MessageRetentionPeriod=86400,ReceiveMessageWaitTimeSeconds=20,RedrivePolicy={\"deadLetterTargetArn\":\"$DLQ_ARN\",\"maxReceiveCount\":\"3\"}" 2>/dev/null || echo "Cola principal ya existe"

echo "✅ Colas SQS de prueba:"
$AWS sqs list-queues | grep emp-test